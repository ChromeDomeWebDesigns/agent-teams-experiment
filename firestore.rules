rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Deny everything by default — only explicitly matched paths are accessible.

    // items — owner-only access
    match /items/{itemId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null
                                  && resource.data.userId == request.auth.uid;

      // valuations — only the parent item's owner may access
      match /valuations/{valId} {
        allow create: if request.auth != null
                      && get(/databases/$(database)/documents/items/$(itemId)).data.userId
                         == request.auth.uid;
        allow read, update, delete: if request.auth != null
                                    && get(/databases/$(database)/documents/items/$(itemId)).data.userId
                                       == request.auth.uid;
      }
    }

    // comps — shared crowd-sourced sales dataset
    // - Any authenticated user may read all comps.
    // - Authenticated users may create a comp only when:
    //     contributedBy == their uid  AND  status == 'user-submitted'
    //     AND required fields are present and typed correctly.
    // - Clients may NOT create seed or verified comps.
    // - Clients may NOT update or delete any comp (POC: no moderation UI).
    // - Unauthenticated access is denied entirely.
    match /comps/{compId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.contributedBy == request.auth.uid
                    && request.resource.data.status == 'user-submitted'
                    && request.resource.data.make is string
                    && request.resource.data.make.size() > 0
                    && request.resource.data.model is string
                    && request.resource.data.model.size() > 0
                    && request.resource.data.modelKey is string
                    && request.resource.data.modelKey.size() > 0
                    && request.resource.data.condition is string
                    && request.resource.data.condition.size() > 0
                    && request.resource.data.salePrice is number
                    && request.resource.data.saleDate is string
                    && request.resource.data.saleDate.size() > 0;

      allow update, delete: if false;
    }

    // logs — authed users may append; no reads, updates, or deletes
    match /logs/{logId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
