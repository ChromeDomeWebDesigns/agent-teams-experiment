# ─────────────────────────────────────────────────────────────────────────────
# SECRETS CONTRACT  (committed; values live only in .env, which is gitignored)
#
# The team references secrets by NAME only and never invents values.
# When a teammate needs a new secret it appends a request to company/PROCUREMENT.md,
# adds the NAME here, and the CEO notifies you. You then put the value in .env.
#
# Copy this file to .env and fill in real values:   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# --- Firebase (client / web SDK) — publishable, safe in the browser ---
# The NUXT_ENV_ prefix is the client-exposure boundary: Nuxt 2 only injects
# NUXT_ENV_*-prefixed vars into the browser bundle. So ONLY non-secret values
# get this prefix. (Real secrets below are intentionally unprefixed so they can
# never reach the client.)
NUXT_ENV_FIREBASE_API_KEY=
NUXT_ENV_FIREBASE_AUTH_DOMAIN=
NUXT_ENV_FIREBASE_PROJECT_ID=
NUXT_ENV_FIREBASE_STORAGE_BUCKET=
NUXT_ENV_FIREBASE_MESSAGING_SENDER_ID=
NUXT_ENV_FIREBASE_APP_ID=

# --- Firebase Admin (server) — TRUE SECRET (unprefixed → never sent to client).
#     Path to a service-account JSON kept OUTSIDE the repo. ---
FIREBASE_SERVICE_ACCOUNT_PATH=

# --- App auth ---
JWT_SECRET=

# Add new required secrets below as the team requests them (name only here).
